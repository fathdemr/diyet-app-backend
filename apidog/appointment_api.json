                    "responses": [
                      {
                        "code": 204,
                        "name": "No Content",
                        "contentType": "application/json",
                        "jsonSchema": {}
                      },
                      {
                        "code": 400,
                        "name": "Bad Request",
                        "contentType": "application/json",
                        "jsonSchema": {
                          "type": "object",
                          "properties": {
                            "message": {
