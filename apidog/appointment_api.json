                              "example": "reason: must not be blank"
                            }
                          }
                        }
                      },
                      {
                        "code": 403,
                        "name": "Forbidden",
                        "contentType": "application/json",
                        "jsonSchema": {
                          "type": "object",
                          "properties": {
                            "message": {
                              "type": "string",
                              "example": "You are not authorized to cancel this appointment"
                            }
                          }
                        }
                      },
                      {
                        "code": 404,
                        "name": "Not Found",
                        "contentType": "application/json",
                        "jsonSchema": {
                          "type": "object",
                          "properties": {
                            "message": {
                              "type": "string",
                              "example": "Appointment not found"
                            }
                          }
                        }
                      },
                      {
                        "code": 409,
                        "name": "Conflict",
                        "contentType": "application/json",
                        "jsonSchema": {
                          "type": "object",
                          "properties": {
                            "message": {
                              "type": "string",
                              "example": "Cannot cancel appointment in status: CANCELLED"
                            }
                          }
                        }
                      }
                    ],
                    "description": "# Randevu İptal Et\n\n## Genel Bakış\nHasta, kendi randevusunu gerekçe belirterek iptal eder. Randevu statüsü `CANCELLED` olarak güncellenir ve ilgili slot tekrar `booked = false` yapılarak başka hastalar için müsait hale gelir.\n\n## HTTP Method & Path\n`PUT /exapi/patient/appointment/cancel/{appointmentId}`\n\n## Yetkilendirme\n- **Rol:** `PATIENT`\n- Bearer JWT token header'da gönderilmelidir\n- Sadece kendi randevusunu iptal edebilir\n\n## Path Parameters\n- **appointmentId** (UUID): İptal edilecek randevunun ID'si\n\n## Request Body\n\n### Gerekli Alanlar\n- **reason** (string): İptal gerekçesi. Boş bırakılamaz.\n\n## Response\n\n### Success (204)\nBoş response body — randevu başarıyla iptal edildi.\n\n### Forbidden (403) — Başka hastanın randevusunu iptal etmeye çalışma\n```json\n{\n  \"message\": \"You are not authorized to cancel this appointment\"\n}\n```\n\n### Conflict (409) — Zaten CANCELLED veya REJECTED statüsünde\n```json\n{\n  \"message\": \"Cannot cancel appointment in status: CANCELLED\"\n}\n```\n\n## Örnek Request\n```bash\ncurl -X PUT http://localhost:8080/exapi/patient/appointment/cancel/661f9511-e30c-42d5-b817-557766551111 \\\n  -H \"Content-Type: application/json\" \\\n  -H \"Authorization: Bearer <token>\" \\\n  -d '{\n    \"reason\": \"Programımda değişiklik oldu, başka bir güne almak istiyorum.\"\n  }'\n```\n\n## Notlar\n- İptal sonrası slot `booked = false` yapılır, başka hasta rezerve edebilir\n- `REJECTED` veya `CANCELLED` statüsündeki randevu iptal edilemez\n- `cancelReason` alanı iptal gerekçesiyle doldurulur"
                  }
                }
              ]
